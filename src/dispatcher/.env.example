# Environment variables for AI Dispatcher

# Google Cloud / Gemini
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_CLOUD_PROJECT=your_project_id

# Service area (comma-separated regions)
SERVICE_AREA=Bucks County,PA,Montgomery County,PA

# HubSpot integration (optional)
HUBSPOT_ACCESS_TOKEN=your_hubspot_token

# Webhook for lead forwarding (optional)
LEAD_WEBHOOK_URL=https://your-webhook-endpoint.com/leads
LEAD_WEBHOOK_SECRET=your_webhook_secret

# Firestore
FIRESTORE_PROJECT_ID=your_project_id